{
  "name": "ermis-ekyc-react",
  "version": "1.1.1",
  "description": "Ermis eKYC React UI SDK – Meeting Preview & Room components",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "bin": {
    "ermis-ekyc-setup": "./bin/ermis-ekyc-setup.cjs"
  },
  "files": [
    "dist",
    "public",
    "scripts",
    "bin",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/copy-assets.cjs"
  },
  "peerDependencies": {
    "ermis-ekyc-sdk": "*",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@ermis-network/ermis-classroom-react": "^2.3.34",
    "@ermis-network/ermis-classroom-sdk": "^2.3.34"
  },
  "devDependencies": {
    "@ermis-network/ermis-classroom-react": "^2.3.34",
    "@ermis-network/ermis-classroom-sdk": "^2.3.34",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "ermis-ekyc-sdk": "file:../../",
    "jsdom": "^28.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "ermis",
    "ekyc",
    "react",
    "meeting",
    "video-call",
    "sdk"
  ],
  "author": "Ermis Network",
  "license": "MIT"
}
